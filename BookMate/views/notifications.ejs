<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notifications</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="https://fonts.googleapis.com/css2?family=Abril+Fatface&family=Raleway:ital,wght@0,100..900;1,100..900&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    <style>
        body {
            background-color: #141416;
            color: white;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
            font-family: 'Roboto', sans-serif;
        }

        main {
            flex: 1;
            padding: 18px;
        }

        footer {
            padding: 15px;
            text-align: center;
        }

        a.copy {
            color: white;
            text-decoration: none;
        }

        .header-container {
            max-width: 600px;
            margin: 0 auto;
            text-align: left;
            padding-top: 15px;
        }

        h1 {
            font-family: 'Raleway', sans-serif;
            margin-bottom: 10px;
        }

        h4 {
            font-family: 'Roboto', sans-serif;
            margin-top: 0;
            font-weight: 400;
            color: #ccc;
        }

        ul {
            list-style: none;
            padding: 0;
            margin: 20px auto;
            max-width: 600px;
        }

        li {
            padding: 10px;
            margin-bottom: 10px;
            border: 1px solid #444;
            border-radius: 5px;
            background-color: #1f2025;
        }

        li a {
            text-decoration: none;
            font-weight: bold;
            color: #4CAF50;
        }

        li a:hover {
            color: #81C784;
        }

        li small {
            display: block;
            margin-top: 5px;
            color: #aaa;
        }
    </style>
</head>
<body>
    <main>
        <h1>Notifications</h1>
        <div class="header-container">
            
            <h4>Welcome, <%= userName %>!</h4>
        </div>
        <% if (notifications.length > 0) { %>
            <ul>
                <% notifications.forEach(notification => { %>
                    <li>
                        <a href="/note/details?noteId=<%= notification.note_id %>">
                            <%= notification.message %>
                        </a>
                        <small><%= new Date(notification.created_at).toLocaleString() %></small>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <p>No notifications yet.</p>
        <% } %>
    </main>
    <footer>
        <a class="text-center copy" href="https://berghzg.com">&copy; Berghz G</a>
    </footer>
</body>
</html>
